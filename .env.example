# ============================================
# 智能简历优化与模拟面试助手 - 环境变量
# ============================================

# 智谱 AI API Key（https://open.bigmodel.cn/）
ZHIPUAI_API_KEY=your_zhipu_api_key_here

# 模型配置
LLM_MODEL_NAME=glm-4v-flash
EMBEDDING_MODEL_NAME=embedding-3
VISION_MODEL_NAME=glm-4v-flash

# 向量检索
FAISS_INDEX_DIR=data/faiss_index
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# KB 检索最高相关性分数低于此值时，自动降级到 web search
KB_RELEVANCE_THRESHOLD=0.35

# 服务配置
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Checkpointer 持久化（生产环境建议配置 PostgreSQL）
# 示例：postgresql://resumeagent:password@postgres:5432/resumeagent?sslmode=disable
CHECKPOINT_DB_URL=
METADATA_DB_URL=

# Expert Cache 后端
# state_checkpointer: 复用 LangGraph checkpoint 持久化（默认）
# postgres: 使用独立 PostgreSQL 缓存表（agent_expert_cache）
EXPERT_CACHE_BACKEND=state_checkpointer
# 留空时会回退使用 CHECKPOINT_DB_URL
EXPERT_CACHE_DB_URL=

# Docker 构建加速
DEBIAN_MIRROR=mirrors.aliyun.com
DEBIAN_MIRROR_SCHEME=http
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_FALLBACK_INDEX_URL=https://pypi.org/simple
PIP_DEFAULT_TIMEOUT=180
PIP_RETRIES=10
