# ============================================
# 多模态文档问答助手 - 环境变量
# ============================================

# 智谱 AI API Key（https://open.bigmodel.cn/）
ZHIPUAI_API_KEY=your_zhipu_api_key_here

# 模型配置
LLM_MODEL_NAME=glm-4v-flash
EMBEDDING_MODEL_NAME=embedding-3
VISION_MODEL_NAME=glm-4v-flash

# 向量检索
FAISS_INDEX_DIR=data/faiss_index
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 服务配置
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Checkpointer 持久化（生产环境建议配置 PostgreSQL）
# 示例：postgresql://resumeagent:password@postgres:5432/resumeagent?sslmode=disable
CHECKPOINT_DB_URL=
